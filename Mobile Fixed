<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>SWARM — Canteen × Colosseum</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=IBM+Plex+Mono:ital,wght@0,400;0,500;0,600;1,400&display=swap" rel="stylesheet">
<style>
*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

:root {
  --black: #000;
  --white: #fff;
  --g100: #d8d8d8;
  --g200: #b0b0b0;
  --g400: #787878;
  --g600: #484848;
  --g700: #303030;
  --g800: #1e1e1e;
  --g900: #111;
  --accent: #00e100;
  --mono: 'IBM Plex Mono', ui-monospace, monospace;
  --pad: 32px;
  --max: 900px;
}

html { scroll-behavior: smooth; }

body {
  background: var(--black);
  color: var(--white);
  font-family: var(--mono);
  font-size: 13px;
  line-height: 1.6;
  -webkit-font-smoothing: antialiased;
  overflow-x: hidden;
}

a { color: inherit; text-decoration: none; }

/* ======================================================
   NAV
   ====================================================== */
.nav {
  position: fixed;
  top: 0; left: 0; right: 0;
  z-index: 200;
  height: 48px;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 var(--pad);
  background: rgba(0,0,0,0.88);
  backdrop-filter: blur(14px);
  -webkit-backdrop-filter: blur(14px);
  border-bottom: 1px solid var(--g800);
}

.nav-brand {
  display: flex; align-items: center; gap: 8px;
  font-size: 13px; font-weight: 500;
}
.nav-x { color: var(--g700); }
.nav-colosseum { color: var(--g400); }
.nav-right { display: flex; align-items: center; gap: 20px; }
.nav-links { display: flex; gap: 20px; }
.nav-links a { font-size: 11px; letter-spacing: 0.06em; color: var(--g600); transition: color 0.1s; }
.nav-links a:hover { color: var(--white); }
.nav-apply {
  font-size: 11px; font-weight: 600; letter-spacing: 0.08em;
  color: var(--black); background: var(--accent);
  padding: 6px 14px; border-radius: 2px; transition: opacity 0.1s;
}
.nav-apply:hover { opacity: 0.85; }

/* ======================================================
   HERO
   ====================================================== */
.hero {
  height: 100vh;
  min-height: 600px;
  position: relative;
  overflow: hidden;
  display: grid;
  grid-template-rows: 1fr auto;
  padding-top: 48px;
}

#ascii-canvas {
  position: absolute;
  inset: 0;
  width: 100%;
  height: 100%;
}

.hero-vignette {
  position: absolute;
  inset: 0;
  background:
    linear-gradient(90deg,
      rgba(0,0,0,0.94) 0%,
      rgba(0,0,0,0.80) 28%,
      rgba(0,0,0,0.50) 55%,
      rgba(0,0,0,0.18) 100%
    ),
    linear-gradient(180deg,
      rgba(0,0,0,0.55) 0%,
      transparent 18%,
      transparent 75%,
      rgba(0,0,0,0.85) 100%
    );
  pointer-events: none;
}

/* Hero body: single wide column, no divider */
.hero-body {
  position: relative;
  z-index: 2;
  display: grid;
  grid-template-columns: 1fr 1fr;
  align-items: center;
  max-width: var(--max);
  width: 100%;
  margin: 0 auto;
  padding: 0 var(--pad);
  gap: 48px;
  height: 100%;
}

.hero-left {
  display: flex;
  flex-direction: column;
  gap: 0;
}

.hero-access {
  font-size: 10px; letter-spacing: 0.18em;
  text-transform: uppercase; color: var(--accent);
  margin-bottom: 20px;
  display: flex; align-items: center; gap: 8px;
}
.hero-access-dot {
  width: 5px; height: 5px; border-radius: 50%;
  background: var(--accent);
  animation: pulse 2s ease-in-out infinite;
}
@keyframes pulse {
  0%,100% { opacity:1; transform:scale(1); box-shadow: 0 0 0 0 rgba(0,225,0,0.4); }
  50% { opacity:0.6; transform:scale(0.8); box-shadow: 0 0 0 6px rgba(0,225,0,0); }
}

.hero-title {
  font-size: clamp(72px, 11vw, 112px);
  font-weight: 600;
  letter-spacing: -0.05em;
  line-height: 0.88;
  color: var(--white);
  margin-bottom: 22px;
  animation: fadein 0.6s ease both;
  display: inline-block;
  cursor: default;
}
.hero-title:hover { animation: glitch 0.3s ease; }
@keyframes glitch {
  0%   { transform: translateX(0); }
  15%  { transform: translateX(-3px); clip-path: inset(20% 0 60% 0); }
  30%  { transform: translateX(3px);  clip-path: inset(60% 0 20% 0); }
  45%  { transform: translateX(-2px); clip-path: inset(40% 0 40% 0); }
  60%  { transform: translateX(2px); }
  75%  { transform: translateX(-1px); }
  100% { transform: translateX(0); }
}

.hero-tagline {
  font-size: 13px;
  color: var(--g100);
  line-height: 1.75;
  margin-bottom: 6px;
  animation: fadein 0.6s ease 0.1s both;
}

.hero-selected {
  font-size: 12px;
  color: var(--g400);
  margin-bottom: 28px;
  animation: fadein 0.6s ease 0.15s both;
}

.hero-ctas {
  display: flex; gap: 10px; flex-wrap: wrap;
  animation: fadein 0.6s ease 0.2s both;
}

.btn-primary {
  font-family: var(--mono); font-size: 12px; font-weight: 600;
  letter-spacing: 0.06em; padding: 10px 20px;
  background: var(--accent); color: var(--black);
  border-radius: 2px; border: none; cursor: pointer;
  text-decoration: none; transition: opacity 0.1s;
  display: inline-flex; align-items: center;
}
.btn-primary:hover { opacity: 0.85; }

.btn-outline {
  font-family: var(--mono); font-size: 12px;
  letter-spacing: 0.06em; padding: 10px 20px;
  background: transparent; color: var(--g200);
  border: 1px solid var(--g700); border-radius: 2px;
  cursor: pointer; text-decoration: none;
  transition: color 0.1s, border-color 0.1s;
  display: inline-flex; align-items: center;
}
.btn-outline:hover { color: var(--white); border-color: var(--g400); }

/* Hero right: meta + canteen stacked */
.hero-right {
  display: flex;
  flex-direction: column;
  gap: 12px;
  animation: fadein 0.6s ease 0.25s both;
}

.meta-grid {
  display: grid; grid-template-columns: 1fr 1fr;
  border: 1px solid var(--g800); border-radius: 2px;
}
.meta-cell {
  padding: 12px 14px;
  border-right: 1px solid var(--g800);
  border-bottom: 1px solid var(--g800);
}
.meta-cell:nth-child(2) { border-right: none; }
.meta-cell:nth-child(3) { border-bottom: none; }
.meta-cell:nth-child(4) { border-right: none; border-bottom: none; }
.meta-key { font-size: 9px; letter-spacing: 0.14em; text-transform: uppercase; color: var(--g600); margin-bottom: 4px; }
.meta-val { font-size: 13px; font-weight: 500; color: var(--white); }
.meta-val.green { color: var(--accent); }

.canteen-card {
  border: 1px solid var(--g800); border-radius: 2px;
  padding: 16px; display: flex; flex-direction: column; gap: 10px;
}
.canteen-header {
  display: flex; align-items: center; gap: 10px;
  padding-bottom: 10px; border-bottom: 1px solid var(--g800);
}
.canteen-mark {
  width: 28px; height: 28px; background: #5b21b6;
  border-radius: 5px; display: flex; align-items: center;
  justify-content: center; font-size: 12px; font-weight: 700;
  color: white; flex-shrink: 0;
}
.canteen-name { font-size: 12px; font-weight: 600; color: var(--white); }
.canteen-sub  { font-size: 10px; color: var(--g600); letter-spacing: 0.05em; margin-top: 1px; }
.canteen-desc { font-size: 12px; color: var(--g100); line-height: 1.7; }
.canteen-desc strong { color: var(--white); font-weight: 500; }
.canteen-swarm {
  font-size: 12px; color: var(--g400); line-height: 1.65;
  padding-top: 10px; border-top: 1px solid var(--g800);
}

/* Terminal log */
.term-block {
  border: 1px solid var(--g800); border-radius: 2px;
  display: flex; flex-direction: column;
  max-height: 160px; overflow: hidden;
}
.term-header {
  display: flex; align-items: center; justify-content: space-between;
  padding: 6px 12px; border-bottom: 1px solid var(--g800);
  background: var(--g900); flex-shrink: 0;
}
.term-title { font-size: 10px; letter-spacing: 0.08em; color: var(--g600); }
.term-live {
  font-size: 10px; letter-spacing: 0.1em; color: var(--accent);
  display: flex; align-items: center; gap: 5px; opacity: 0.8;
}
.term-live-dot {
  width: 5px; height: 5px; border-radius: 50%;
  background: var(--accent);
  animation: blink 1.4s ease-in-out infinite;
}
@keyframes blink { 0%,100%{opacity:1} 50%{opacity:0.2} }
.term-log {
  flex: 1; overflow-y: auto; padding: 7px 12px;
  display: flex; flex-direction: column; gap: 1px;
  scrollbar-width: none;
}
.term-log::-webkit-scrollbar { display: none; }
.term-line { font-size: 10px; letter-spacing: 0.03em; line-height: 1.5; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
.term-sys   { color: var(--g600); }
.term-spawn { color: var(--g400); }
.term-tx    { color: var(--accent); opacity: 0.75; }

/* Status bar */
.hero-bottom {
  position: relative; z-index: 2;
  display: flex; align-items: center; justify-content: space-between;
  padding: 0 var(--pad);
  height: 38px;
  border-top: 1px solid var(--g800);
  font-size: 11px; color: var(--g600);
  background: rgba(0,0,0,0.65);
  backdrop-filter: blur(8px);
}
.hero-bottom-left { display: flex; align-items: center; gap: 16px; }
.hero-bottom-right { display: flex; align-items: center; gap: 14px; }
.hero-bottom-right a { color: var(--g600); font-size: 11px; letter-spacing: 0.04em; transition: color 0.1s; }
.hero-bottom-right a:hover { color: var(--white); }

.scroll-hint {
  font-size: 14px; color: var(--g500, #585858);
  animation: bounce 2s ease-in-out 2s infinite;
}
@keyframes bounce {
  0%,100% { transform: translateY(0); }
  50% { transform: translateY(3px); }
}

@keyframes fadein {
  from { opacity:0; transform: translateY(10px); }
  to   { opacity:1; transform: translateY(0); }
}

/* ======================================================
   TICKER
   ====================================================== */
.ticker-bar {
  background: var(--g900);
  border-bottom: 1px solid var(--g800);
  padding: 7px 0;
  overflow: hidden;
}
.ticker-inner {
  display: flex;
  animation: ticker 32s linear infinite;
  width: max-content;
}
@keyframes ticker { from{transform:translateX(0)} to{transform:translateX(-50%)} }
.ticker-item { font-size: 11px; color: var(--g600); padding: 0 28px; white-space: nowrap; letter-spacing: 0.06em; }
.ticker-item::after { content: '·'; margin-left: 28px; color: var(--g800); }
.ticker-item.accent { color: var(--accent); opacity: 0.7; }

/* ======================================================
   SECTIONS
   ====================================================== */
.section {
  border-top: 1px solid var(--g800);
  max-width: var(--max);
  margin: 0 auto;
  padding: 0 var(--pad);
  display: grid;
  grid-template-columns: 140px 1fr;
}

.sec-label {
  padding: 32px 0;
  border-right: 1px solid var(--g800);
  padding-right: 20px;
}
.sec-label-text { font-size: 10px; letter-spacing: 0.12em; text-transform: uppercase; color: var(--g600); line-height: 1.5; }
.sec-label-num { font-size: 11px; color: var(--g800); margin-top: 4px; }
.sec-body { padding: 32px 0 32px 28px; }

/* ======================================================
   PRIZES
   ====================================================== */
.prize-hero {
  display: flex;
  align-items: baseline;
  gap: 12px;
  margin-bottom: 16px;
}
.prize-num {
  font-size: clamp(44px, 6vw, 64px);
  font-weight: 600;
  letter-spacing: -0.04em;
  line-height: 1;
  color: var(--white);
}
.prize-context { font-size: 12px; color: var(--g600); max-width: 280px; line-height: 1.5; }

.prize-stack {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 1px;
  background: var(--g800);
  border: 1px solid var(--g800);
  border-radius: 2px;
  overflow: hidden;
  margin-bottom: 24px;
}
.prize-tile {
  background: var(--black);
  padding: 16px 18px;
}
.prize-tile-lbl { font-size: 9px; letter-spacing: 0.14em; text-transform: uppercase; color: var(--g600); margin-bottom: 6px; }
.prize-tile-val { font-size: 22px; font-weight: 600; letter-spacing: -0.03em; color: var(--white); margin-bottom: 3px; }
.prize-tile-val.green { color: var(--accent); }
.prize-tile-desc { font-size: 11px; color: var(--g600); line-height: 1.5; }

.perk-list { display: flex; flex-direction: column; margin-top: 8px; }
.perk-row { display: flex; gap: 14px; padding: 10px 0; border-top: 1px solid var(--g800); }
.perk-row:first-child { border-top: none; padding-top: 0; }
.perk-n { font-size: 10px; color: var(--g700); min-width: 18px; padding-top: 1px; flex-shrink: 0; }
.perk-title { font-size: 13px; font-weight: 500; color: var(--white); margin-bottom: 2px; }
.perk-desc-t { font-size: 12px; color: var(--g400); line-height: 1.6; }

/* ======================================================
   PRIORITY PASS
   ====================================================== */
.pass-grid { display: grid; grid-template-columns: 1fr 1fr; border: 1px solid var(--g800); border-radius: 2px; overflow: hidden; }
.pass-col { padding: 18px; }
.pass-col:first-child { border-right: 1px solid var(--g800); }
.pass-lbl { font-size: 10px; letter-spacing: 0.12em; text-transform: uppercase; color: var(--g600); margin-bottom: 7px; }
.pass-col:last-child .pass-lbl { color: var(--accent); }
.pass-title { font-size: 15px; font-weight: 600; color: var(--white); margin-bottom: 8px; }
.pass-col:last-child .pass-title { color: var(--accent); }
.pass-body { font-size: 12px; color: var(--g400); line-height: 1.7; margin-bottom: 12px; }
.pass-foot { font-size: 10px; letter-spacing: 0.1em; text-transform: uppercase; color: var(--g600); padding-top: 10px; border-top: 1px solid var(--g800); }
.pass-col:last-child .pass-foot { color: var(--accent); opacity: 0.7; border-top-color: rgba(0,225,0,0.15); }

/* ======================================================
   RFBs — ACCORDION
   ====================================================== */
.rfb-intro { font-size: 13px; color: var(--g200); line-height: 1.7; max-width: 520px; margin-bottom: 20px; }
.rfb-intro strong { color: var(--white); font-weight: 500; }
.rfb-intro a { color: var(--accent); text-decoration: underline; text-underline-offset: 3px; }

.rfb-list { display: flex; flex-direction: column; border: 1px solid var(--g800); border-radius: 2px; overflow: hidden; }

.rfb-item { border-bottom: 1px solid var(--g800); }
.rfb-item:last-child { border-bottom: none; }

/* The clickable header row */
.rfb-trigger {
  width: 100%;
  background: none;
  border: none;
  cursor: pointer;
  text-align: left;
  padding: 16px 18px;
  display: flex;
  align-items: center;
  gap: 14px;
  font-family: var(--mono);
  transition: background 0.12s;
  user-select: none;
}
.rfb-trigger:hover { background: rgba(255,255,255,0.025); }
.rfb-item.open > .rfb-trigger { background: rgba(0,225,0,0.03); }

.rfb-n {
  font-size: 10px; color: var(--g700);
  min-width: 36px; flex-shrink: 0;
  letter-spacing: 0.04em; padding-top: 1px;
  transition: color 0.15s;
}
.rfb-item.open > .rfb-trigger .rfb-n { color: var(--accent); }

.rfb-trigger-main { flex: 1; }
.rfb-t-title { font-size: 13px; font-weight: 500; color: var(--white); margin-bottom: 2px; }
.rfb-t-sub { font-size: 11px; color: var(--g600); font-style: italic; }

/* Plus/minus toggle */
.rfb-toggle {
  font-size: 18px;
  color: var(--g700);
  flex-shrink: 0;
  line-height: 1;
  width: 20px;
  text-align: center;
  transition: color 0.15s, transform 0.2s;
}
.rfb-item.open > .rfb-trigger .rfb-toggle {
  color: var(--accent);
  transform: rotate(45deg);
}

/* Expanded body — hidden by default */
.rfb-body {
  display: none;
  padding: 0 18px 20px 70px;
  border-top: 1px solid var(--g800);
  background: rgba(255,255,255,0.012);
}
.rfb-item.open > .rfb-body { display: block; }

.rfb-body-inner { padding-top: 16px; }

.rfb-problem {
  border-left: 2px solid var(--accent);
  padding: 8px 12px;
  margin-bottom: 16px;
  font-size: 12px;
  color: var(--g200);
  line-height: 1.75;
}

.sub-lbl {
  font-size: 9px; letter-spacing: 0.12em;
  text-transform: uppercase; color: var(--g600);
  margin-bottom: 6px; margin-top: 14px;
}
.sub-lbl:first-of-type { margin-top: 0; }

.bl { list-style: none; display: flex; flex-direction: column; gap: 4px; }
.bl li { font-size: 12px; color: var(--g400); display: flex; gap: 8px; line-height: 1.55; }
.bl li::before { content: '—'; color: var(--g700); flex-shrink: 0; }

.ql { list-style: none; display: flex; flex-direction: column; gap: 4px; }
.ql li { font-size: 12px; color: var(--g600); font-style: italic; display: flex; gap: 8px; line-height: 1.55; }
.ql li::before { content: '?'; color: var(--accent); font-style: normal; flex-shrink: 0; font-size: 11px; }

.rfb-ex {
  margin-top: 14px; padding: 10px 12px;
  border: 1px solid var(--g800); border-radius: 2px;
  background: var(--g900);
}
.rfb-ex-lbl { font-size: 9px; letter-spacing: 0.1em; text-transform: uppercase; color: var(--accent); margin-bottom: 5px; opacity: 0.65; }
.rfb-ex p { font-size: 12px; color: var(--g400); line-height: 1.65; }

/* ======================================================
   EARLY BUILDER EXAMPLES
   ====================================================== */
.example-list { display: flex; flex-direction: column; }
.example-item { border-top: 1px solid var(--g800); padding: 16px 0; }
.example-item:first-child { border-top: none; padding-top: 0; }
.example-header { display: flex; gap: 12px; margin-bottom: 8px; align-items: flex-start; }
.example-n { font-size: 10px; color: var(--accent); min-width: 36px; padding-top: 2px; letter-spacing: 0.04em; flex-shrink: 0; }
.example-title { font-size: 13px; font-weight: 500; color: var(--white); margin-bottom: 3px; line-height: 1.4; }
.example-attr { font-size: 11px; color: var(--g600); letter-spacing: 0.03em; }
.example-body { padding-left: 48px; }
.example-desc { font-size: 12px; color: var(--g400); line-height: 1.75; margin-bottom: 8px; }
.example-link { display: inline-flex; align-items: center; gap: 4px; font-size: 11px; color: var(--g600); letter-spacing: 0.04em; transition: color 0.1s; text-decoration: none; }
.example-link:hover { color: var(--accent); }

/* ======================================================
   JUDGING
   ====================================================== */
.j-grid { display: grid; grid-template-columns: 1fr 1fr 1fr; gap: 1px; background: var(--g800); border: 1px solid var(--g800); border-radius: 2px; overflow: hidden; margin-bottom: 20px; }
.j-card { background: var(--black); padding: 20px 18px; }
.j-pct { font-size: 32px; font-weight: 600; letter-spacing: -0.03em; line-height: 1; margin-bottom: 8px; }
.j-card:nth-child(1) .j-pct { color: var(--accent); }
.j-card:nth-child(2) .j-pct { color: var(--white); }
.j-card:nth-child(3) .j-pct { color: var(--g200); }
.j-name { font-size: 12px; font-weight: 600; color: var(--white); margin-bottom: 6px; }
.j-desc { font-size: 11px; color: var(--g400); line-height: 1.65; }
.j-levels { margin-top: 10px; display: flex; flex-direction: column; gap: 4px; }
.j-lv { display: flex; align-items: center; gap: 6px; font-size: 10px; color: var(--g600); }
.j-dot { width: 4px; height: 4px; border-radius: 50%; flex-shrink: 0; }
.j-dot.hi { background: var(--white); }
.j-dot.md { background: var(--g600); }
.j-dot.lo { background: transparent; border: 1px solid var(--g700); }

.j-note { font-size: 12px; color: var(--g400); line-height: 1.7; max-width: 520px; }
.j-note strong { color: var(--white); font-weight: 500; }

/* ======================================================
   RESOURCES
   ====================================================== */
.res-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 24px; }
.res-group-title { font-size: 10px; letter-spacing: 0.1em; text-transform: uppercase; color: var(--g600); margin-bottom: 6px; padding-bottom: 6px; border-bottom: 1px solid var(--g800); }
.res-links { display: flex; flex-direction: column; gap: 1px; }
.res-link { display: flex; align-items: center; justify-content: space-between; padding: 7px 8px; border-radius: 2px; text-decoration: none; transition: background 0.1s; gap: 10px; }
.res-link:hover { background: rgba(255,255,255,0.04); }
.res-link-name { font-size: 13px; font-weight: 500; color: var(--white); }
.res-link-desc { font-size: 11px; color: var(--g600); flex: 1; text-align: right; font-style: italic; }
.res-link-arr { font-size: 10px; color: var(--g700); }

/* ======================================================
   CTA SECTION — bigger, more impact
   ====================================================== */
.cta-section {
  border-top: 1px solid var(--g800);
  position: relative;
  overflow: hidden;
}

.cta-inner {
  max-width: var(--max);
  margin: 0 auto;
  padding: 64px var(--pad);
  position: relative;
  z-index: 2;
}

/* Subtle green glow behind CTA */
.cta-section::before {
  content: '';
  position: absolute;
  top: 50%; left: 50%;
  transform: translate(-50%, -50%);
  width: 600px; height: 300px;
  background: radial-gradient(ellipse, rgba(0,225,0,0.04) 0%, transparent 70%);
  pointer-events: none;
}

.cta-lbl {
  font-size: 10px; letter-spacing: 0.14em;
  text-transform: uppercase; color: var(--accent);
  margin-bottom: 12px;
  display: flex; align-items: center; gap: 8px;
}
.cta-lbl::before {
  content: '';
  display: inline-block;
  width: 6px; height: 6px;
  border-radius: 50%;
  background: var(--accent);
  animation: pulse 2s ease-in-out infinite;
}

.cta-title {
  font-size: clamp(32px, 5vw, 52px);
  font-weight: 600; letter-spacing: -0.04em;
  line-height: 1.0; color: var(--white);
  margin-bottom: 14px;
}

.cta-sub { font-size: 13px; color: var(--g400); line-height: 1.75; max-width: 400px; margin-bottom: 28px; }

.cta-actions { display: flex; gap: 10px; align-items: center; flex-wrap: wrap; }

.cta-fine { margin-top: 20px; font-size: 11px; color: var(--g700); letter-spacing: 0.04em; }

/* ======================================================
   MODAL
   ====================================================== */
.modal-overlay {
  display: none;
  position: fixed; inset: 0; z-index: 500;
  background: rgba(0,0,0,0.85);
  backdrop-filter: blur(8px);
  -webkit-backdrop-filter: blur(8px);
  align-items: center; justify-content: center;
  padding: var(--pad);
}
.modal-overlay.open { display: flex; }
.modal-box {
  background: var(--g900);
  border: 1px solid var(--g700);
  border-radius: 2px;
  padding: 32px;
  max-width: 380px; width: 100%;
  position: relative;
}
.modal-close {
  position: absolute; top: 14px; right: 16px;
  background: none; border: none; cursor: pointer;
  font-size: 20px; color: var(--g600);
  font-family: var(--mono); line-height: 1;
  transition: color 0.1s; padding: 0;
}
.modal-close:hover { color: var(--white); }
.modal-lbl { font-size: 10px; letter-spacing: 0.14em; text-transform: uppercase; color: var(--accent); margin-bottom: 10px; }
.modal-title { font-size: 18px; font-weight: 600; color: var(--white); letter-spacing: -0.02em; margin-bottom: 8px; }
.modal-desc { font-size: 12px; color: var(--g400); line-height: 1.7; margin-bottom: 20px; }
.modal-pass {
  border: 1px solid var(--g800); border-radius: 2px;
  padding: 12px 16px; margin-bottom: 20px;
  background: var(--black);
}
.modal-pass-lbl { font-size: 10px; letter-spacing: 0.1em; text-transform: uppercase; color: var(--g600); margin-bottom: 5px; }
.modal-pass-val { font-size: 22px; font-weight: 600; color: var(--accent); letter-spacing: 0.06em; }
.modal-cta { display: block; text-align: center; }

/* ======================================================
   FOOTER
   ====================================================== */
.footer {
  border-top: 1px solid var(--g800);
  max-width: var(--max); margin: 0 auto;
  padding: 16px var(--pad);
  display: flex; align-items: center; justify-content: space-between;
  font-size: 11px; color: var(--g700); gap: 12px; flex-wrap: wrap;
}
.footer a { color: var(--g600); transition: color 0.1s; }
.footer a:hover { color: var(--white); }

/* ======================================================
   RESPONSIVE
